# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Optional — app runs fine with this unset (Dashboard tab shows setup
# instructions instead of stats, pipeline runs just aren't persisted).
# Needed only for Phase 7 (Dashboard). MongoDB Atlas free M0 tier (512MB,
# no credit card) is plenty — mongodb.com/cloud/atlas
MONGO_URI=

# Needed only for Phase 4 (Summarizer). Either one works — both free, no
# credit card required. Gemini key: aistudio.google.com. Groq key:
# console.groq.com. If both are set, Gemini is used by default.
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional tuning — sensible defaults if left unset
# GEMINI_MODEL=gemini-2.5-flash-lite   # higher free-tier quota than gemini-2.5-flash
# GROQ_MODEL=llama-3.1-8b-instant
# LLM_TIMEOUT_MS=20000
# EMBEDDING_LOAD_TIMEOUT_MS=30000
# RATE_LIMIT_GENERAL_PER_MIN=60        # all /api routes, per IP
# RATE_LIMIT_LLM_PER_5MIN=8            # summarize/evaluate/pipeline only, per IP —
#                                       # what actually protects your free-tier quota
#                                       # on a public demo. Visitors with their own
#                                       # key (Settings, in the app) bypass this.
